{
  "version": "1.0.0",
  "name": "ProgramData 目录分析规则集",
  "description": "Light-C 的 ProgramData 目录分析规则，支持在线更新",
  "updated_at": "2026-04-21",
  "rules": [
    {
      "id": "win-delivery-optimization",
      "name": "Windows 传递优化缓存",
      "match_mode": "contains",
      "pattern": "Microsoft/Windows/DeliveryOptimization",
      "category": "Windows Update",
      "risk": "safe",
      "action": "delete",
      "description": "Windows 更新的 P2P 分发缓存，可安全删除",
      "suggestion": "删除后不影响系统，Windows 会在需要时重新下载",
      "min_size": 0,
      "priority": 100,
      "enabled": true,
      "tags": ["windows", "update", "cache"]
    },
    {
      "id": "win-softwaredistribution",
      "name": "Windows Update 下载缓存",
      "match_mode": "contains",
      "pattern": "Microsoft/Windows/SoftwareDistribution",
      "category": "Windows Update",
      "risk": "warning",
      "action": "suggest",
      "description": "Windows Update 下载的更新包缓存",
      "suggestion": "建议在 Windows Update 完成后清理",
      "min_size": 104857600,
      "priority": 90,
      "enabled": true,
      "tags": ["windows", "update"]
    },
    {
      "id": "win-wer",
      "name": "Windows 错误报告",
      "match_mode": "contains",
      "pattern": "Microsoft/Windows/WER",
      "category": "Windows Error",
      "risk": "safe",
      "action": "delete",
      "description": "Windows 错误报告和崩溃转储文件",
      "suggestion": "可以安全删除，不影响系统运行",
      "min_size": 0,
      "priority": 100,
      "enabled": true,
      "tags": ["windows", "error", "dump"]
    },
    {
      "id": "win-temp",
      "name": "Windows 临时文件",
      "match_mode": "contains",
      "pattern": "Microsoft/Windows/Temp",
      "category": "Temp Files",
      "risk": "safe",
      "action": "delete",
      "description": "Windows 系统临时文件",
      "suggestion": "可以安全删除",
      "min_size": 0,
      "priority": 100,
      "enabled": true,
      "tags": ["windows", "temp"]
    },
    {
      "id": "defender-scans",
      "name": "Defender 扫描历史",
      "match_mode": "contains",
      "pattern": "Microsoft/Windows Defender/Scans",
      "category": "Defender",
      "risk": "safe",
      "action": "suggest",
      "description": "Windows Defender 的扫描历史和隔离文件",
      "suggestion": "可以清理旧的扫描记录，保留最近的",
      "min_size": 52428800,
      "priority": 80,
      "enabled": true,
      "tags": ["defender", "security"]
    },
    {
      "id": "defender-definition",
      "name": "Defender 病毒定义",
      "match_mode": "contains",
      "pattern": "Microsoft/Windows Defender/Definition Updates",
      "category": "Defender",
      "risk": "dangerous",
      "action": "protect",
      "description": "Windows Defender 病毒库定义文件",
      "suggestion": "请勿删除，这是系统安全的重要组成部分",
      "min_size": 0,
      "priority": 200,
      "enabled": true,
      "tags": ["defender", "security", "protected"]
    },
    {
      "id": "defender-platform",
      "name": "Defender 平台文件",
      "match_mode": "contains",
      "pattern": "Microsoft/Windows Defender/Platform",
      "category": "Defender",
      "risk": "dangerous",
      "action": "protect",
      "description": "Windows Defender 核心引擎文件",
      "suggestion": "请勿删除，删除会导致系统防护失效",
      "min_size": 0,
      "priority": 200,
      "enabled": true,
      "tags": ["defender", "security", "protected"]
    },
    {
      "id": "nvidia-cache",
      "name": "NVIDIA 驱动缓存",
      "match_mode": "prefix",
      "pattern": "NVIDIA Corporation",
      "category": "Driver Cache",
      "risk": "safe",
      "action": "suggest",
      "description": "NVIDIA 显卡驱动的着色器缓存和临时文件",
      "suggestion": "可以清理，驱动会自动重建缓存",
      "min_size": 104857600,
      "priority": 70,
      "enabled": true,
      "tags": ["driver", "nvidia", "cache"]
    },
    {
      "id": "nvidia-installer",
      "name": "NVIDIA 安装包",
      "match_mode": "contains",
      "pattern": "NVIDIA Corporation/Installer",
      "category": "Driver Cache",
      "risk": "safe",
      "action": "delete",
      "description": "NVIDIA 驱动安装包缓存",
      "suggestion": "旧版驱动安装包，可以安全删除",
      "min_size": 0,
      "priority": 80,
      "enabled": true,
      "tags": ["driver", "nvidia", "installer"]
    },
    {
      "id": "amd-cache",
      "name": "AMD 驱动缓存",
      "match_mode": "prefix",
      "pattern": "AMD",
      "category": "Driver Cache",
      "risk": "safe",
      "action": "suggest",
      "description": "AMD 显卡驱动缓存文件",
      "suggestion": "可以清理，驱动会自动重建",
      "min_size": 104857600,
      "priority": 70,
      "enabled": true,
      "tags": ["driver", "amd", "cache"]
    },
    {
      "id": "intel-data",
      "name": "Intel 驱动数据",
      "match_mode": "prefix",
      "pattern": "Intel",
      "category": "Driver",
      "risk": "warning",
      "action": "ignore",
      "description": "Intel 驱动程序数据",
      "suggestion": "建议保留，可能包含重要配置",
      "min_size": 0,
      "priority": 60,
      "enabled": true,
      "tags": ["driver", "intel"]
    },
    {
      "id": "realtek-data",
      "name": "Realtek 驱动数据",
      "match_mode": "prefix",
      "pattern": "Realtek",
      "category": "Driver",
      "risk": "warning",
      "action": "ignore",
      "description": "Realtek 音频/网卡驱动数据",
      "suggestion": "建议保留",
      "min_size": 0,
      "priority": 60,
      "enabled": true,
      "tags": ["driver", "realtek"]
    },
    {
      "id": "package-cache",
      "name": "软件包缓存",
      "match_mode": "exact",
      "pattern": "Package Cache",
      "category": "Package Cache",
      "risk": "warning",
      "action": "suggest",
      "description": "Visual Studio 等软件的安装包缓存",
      "suggestion": "清理后可能影响软件修复/卸载，建议保留",
      "min_size": 524288000,
      "priority": 50,
      "enabled": true,
      "tags": ["package", "installer"]
    },
    {
      "id": "chocolatey",
      "name": "Chocolatey 包管理器",
      "match_mode": "prefix",
      "pattern": "chocolatey",
      "category": "Package Manager",
      "risk": "dangerous",
      "action": "protect",
      "description": "Chocolatey 包管理器数据",
      "suggestion": "请勿删除，这是包管理器的核心数据",
      "min_size": 0,
      "priority": 200,
      "enabled": true,
      "tags": ["package", "chocolatey", "protected"]
    },
    {
      "id": "docker-data",
      "name": "Docker 数据",
      "match_mode": "prefix",
      "pattern": "Docker",
      "category": "Application",
      "risk": "dangerous",
      "action": "protect",
      "description": "Docker 容器和镜像数据",
      "suggestion": "请勿直接删除，使用 docker system prune 清理",
      "min_size": 0,
      "priority": 200,
      "enabled": true,
      "tags": ["docker", "container", "protected"]
    },
    {
      "id": "adobe-cache",
      "name": "Adobe 缓存",
      "match_mode": "prefix",
      "pattern": "Adobe",
      "category": "Application",
      "risk": "safe",
      "action": "suggest",
      "description": "Adobe 软件的缓存和临时文件",
      "suggestion": "可以清理缓存，不影响软件使用",
      "min_size": 209715200,
      "priority": 60,
      "enabled": true,
      "tags": ["adobe", "cache"]
    },
    {
      "id": "microsoft-office",
      "name": "Microsoft Office 数据",
      "match_mode": "contains",
      "pattern": "Microsoft/Office",
      "category": "Application",
      "risk": "warning",
      "action": "ignore",
      "description": "Microsoft Office 应用程序数据",
      "suggestion": "建议保留，包含 Office 配置和缓存",
      "min_size": 0,
      "priority": 70,
      "enabled": true,
      "tags": ["microsoft", "office"]
    },
    {
      "id": "microsoft-teams",
      "name": "Microsoft Teams 数据",
      "match_mode": "contains",
      "pattern": "Microsoft/Teams",
      "category": "Application",
      "risk": "warning",
      "action": "ignore",
      "description": "Microsoft Teams 应用程序数据",
      "suggestion": "建议保留",
      "min_size": 0,
      "priority": 70,
      "enabled": true,
      "tags": ["microsoft", "teams"]
    },
    {
      "id": "regid",
      "name": "软件注册信息",
      "match_mode": "prefix",
      "pattern": "regid.",
      "category": "System",
      "risk": "dangerous",
      "action": "protect",
      "description": "软件许可证和注册信息",
      "suggestion": "请勿删除，可能导致软件激活失效",
      "min_size": 0,
      "priority": 200,
      "enabled": true,
      "tags": ["system", "license", "protected"]
    },
    {
      "id": "ssh",
      "name": "SSH 配置",
      "match_mode": "exact",
      "pattern": "ssh",
      "category": "System",
      "risk": "dangerous",
      "action": "protect",
      "description": "OpenSSH 服务器配置和密钥",
      "suggestion": "请勿删除，包含重要的安全配置",
      "min_size": 0,
      "priority": 200,
      "enabled": true,
      "tags": ["system", "ssh", "protected"]
    },
    {
      "id": "usoShared",
      "name": "Windows 更新服务",
      "match_mode": "exact",
      "pattern": "USOShared",
      "category": "Windows Update",
      "risk": "warning",
      "action": "ignore",
      "description": "Windows Update Orchestrator 服务数据",
      "suggestion": "系统更新服务数据，建议保留",
      "min_size": 0,
      "priority": 80,
      "enabled": true,
      "tags": ["windows", "update"]
    },
    {
      "id": "windowsholographicdevices",
      "name": "Windows 全息设备",
      "match_mode": "exact",
      "pattern": "WindowsHolographicDevices",
      "category": "System",
      "risk": "safe",
      "action": "suggest",
      "description": "Windows Mixed Reality 设备数据",
      "suggestion": "如果不使用 VR 设备，可以清理",
      "min_size": 0,
      "priority": 50,
      "enabled": true,
      "tags": ["windows", "vr"]
    },
    {
      "id": "installer-cache",
      "name": "安装程序缓存",
      "match_mode": "contains",
      "pattern": "/Installer",
      "category": "Installer Cache",
      "risk": "safe",
      "action": "suggest",
      "description": "软件安装程序缓存",
      "suggestion": "可以清理旧的安装包缓存",
      "min_size": 104857600,
      "priority": 40,
      "enabled": true,
      "tags": ["installer", "cache"]
    },
    {
      "id": "crash-dumps",
      "name": "崩溃转储",
      "match_mode": "contains",
      "pattern": "CrashDump",
      "category": "Crash Dumps",
      "risk": "safe",
      "action": "delete",
      "description": "程序崩溃时生成的转储文件",
      "suggestion": "可以安全删除，除非需要调试问题",
      "min_size": 0,
      "priority": 90,
      "enabled": true,
      "tags": ["crash", "dump"]
    },
    {
      "id": "logs-generic",
      "name": "日志文件",
      "match_mode": "contains",
      "pattern": "/Logs",
      "category": "Logs",
      "risk": "safe",
      "action": "suggest",
      "description": "应用程序日志文件",
      "suggestion": "可以清理旧日志，保留最近的用于排查问题",
      "min_size": 52428800,
      "priority": 30,
      "enabled": true,
      "tags": ["logs"]
    }
  ]
}
