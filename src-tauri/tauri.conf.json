{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LightC",
  "version": "2.2.1",
  "identifier": "com.chunyu.LightC",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1666",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LightC",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 450,
        "center": true,
        "decorations": false,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "LightC",
        "width": 400,
        "height": 320,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  }
}
